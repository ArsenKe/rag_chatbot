generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  admin
  manager
  driver
}

enum DriverStatus {
  active
  inactive
}

enum CarStatus {
  available
  rented
  maintenance
}

enum BookingStatus {
  reserved
  confirmed
  completed
  cancelled
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  role      Role
  driverId  BigInt?
  createdAt DateTime @default(now())
}

model Driver {
  id            BigInt               @id @default(autoincrement())
  name          String
  licenseNumber String               @unique
  phone         String?
  hireDate      DateTime?
  status        DriverStatus         @default(active)
  availabilities DriverAvailability[]
  trips         Trip[]
}

model Car {
  id           BigInt          @id @default(autoincrement())
  licensePlate String          @unique
  model        String
  make         String
  year         Int?
  seats        Int?
  transmission String?
  fuelType     String?
  carClass     String?
  status       CarStatus       @default(available)
  trips        Trip[]
  maintenance  MaintenanceLog[]
}

model Customer {
  id               BigInt    @id @default(autoincrement())
  name             String
  email            String?
  phone            String?
  address          String?
  driverLicense    String?
  registrationDate DateTime?
  bookings         Booking[]
  trips            Trip[]
}

model Location {
  id         BigInt @id @default(autoincrement())
  name       String
  address    String?
  city       String?
  postalCode String?
  type       String

  pickupBookings  Booking[] @relation("bookingPickup")
  dropoffBookings Booking[] @relation("bookingDropoff")
  pickupTrips  Trip[] @relation("pickupLocation")
  dropoffTrips Trip[] @relation("dropoffLocation")
}

model Booking {
  id                BigInt        @id @default(autoincrement())
  customerId        BigInt
  pickupLocationId  BigInt
  dropoffLocationId BigInt
  requestedStart    DateTime
  requestedEnd      DateTime
  carClass          String?
  status            BookingStatus @default(reserved)
  notes             String?
  createdAt         DateTime      @default(now())

  customer       Customer @relation(fields: [customerId], references: [id])
  pickupLocation Location @relation("bookingPickup", fields: [pickupLocationId], references: [id])
  dropoffLocation Location @relation("bookingDropoff", fields: [dropoffLocationId], references: [id])
  trip           Trip?

  @@index([requestedStart, requestedEnd])
}

model Trip {
  id                BigInt        @id @default(autoincrement())
  bookingId         BigInt?       @unique
  driverId          BigInt
  carId             BigInt
  customerId        BigInt
  pickupLocationId  BigInt
  dropoffLocationId BigInt
  startTime         DateTime
  endTime           DateTime
  status            BookingStatus @default(confirmed)
  durationMinutes   Int
  distanceKm        Decimal?      @db.Decimal(10, 2)
  fareAmount        Decimal       @db.Decimal(12, 2)
  discountAmount    Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal       @db.Decimal(12, 2)

  booking         Booking?  @relation(fields: [bookingId], references: [id])
  driver          Driver    @relation(fields: [driverId], references: [id])
  car             Car       @relation(fields: [carId], references: [id])
  customer        Customer  @relation(fields: [customerId], references: [id])
  pickupLocation  Location  @relation("pickupLocation", fields: [pickupLocationId], references: [id])
  dropoffLocation Location  @relation("dropoffLocation", fields: [dropoffLocationId], references: [id])
  payments        Payment[]

  @@index([startTime, endTime])
  @@index([driverId, startTime])
  @@index([carId, startTime])
}

model DriverAvailability {
  id          BigInt   @id @default(autoincrement())
  driverId    BigInt
  shiftStart  DateTime
  shiftEnd    DateTime
  isAvailable Boolean  @default(true)

  driver Driver @relation(fields: [driverId], references: [id])

  @@index([driverId, shiftStart, shiftEnd])
}

model MaintenanceLog {
  id          BigInt   @id @default(autoincrement())
  carId       BigInt
  serviceDate DateTime
  details     String
  cost        Decimal? @db.Decimal(12, 2)

  car Car @relation(fields: [carId], references: [id])
}

model Payment {
  id        BigInt   @id @default(autoincrement())
  tripId    BigInt
  amount    Decimal  @db.Decimal(12, 2)
  method    String
  paidAt    DateTime @default(now())

  trip Trip @relation(fields: [tripId], references: [id])
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  actorUserId String
  action      String
  entityType  String
  entityId    String
  oldValue    Json?
  newValue    Json?
  createdAt   DateTime @default(now())
}

// Star schema for analytics
model DimDriver {
  driverId       BigInt @id
  name           String
  licenseNumber  String @unique
  phone          String?
  hireDate       DateTime?
  status         String
  factTrips      FactTrip[]
}

model DimCar {
  carId          BigInt @id
  licensePlate   String @unique
  model          String
  make           String
  year           Int?
  seats          Int?
  transmission   String?
  fuelType       String?
  status         String
  factTrips      FactTrip[]
}

model DimCustomer {
  customerId       BigInt @id
  name             String
  email            String?
  phone            String?
  address          String?
  driverLicense    String?
  registrationDate DateTime?
  factTrips        FactTrip[]
}

model DimLocation {
  locationId BigInt @id
  name       String
  address    String?
  city       String?
  postalCode String?
  type       String

  pickupFacts  FactTrip[] @relation("factPickup")
  dropoffFacts FactTrip[] @relation("factDropoff")
}

model DimDate {
  dateId     Int @id
  fullDate   DateTime @unique
  year       Int
  quarter    Int
  month      Int
  day        Int
  weekday    Int
  isWeekend  Boolean
  factTrips  FactTrip[]
}

model DimTime {
  timeId      Int @id
  hour        Int
  minute      Int
  timeOfDay   String

  startFacts  FactTrip[] @relation("factStartTime")
  endFacts    FactTrip[] @relation("factEndTime")
}

model DimBookingStatus {
  statusId    Int @id
  statusName  String @unique
  factTrips   FactTrip[]
}

model FactTrip {
  tripId             BigInt @id @default(autoincrement())
  dateId             Int
  timeIdStart        Int
  timeIdEnd          Int
  driverId           BigInt
  carId              BigInt
  customerId         BigInt
  pickupLocationId   BigInt
  dropoffLocationId  BigInt
  statusId           Int
  durationMinutes    Int
  distanceKm         Decimal? @db.Decimal(10, 2)
  fareAmount         Decimal @db.Decimal(12, 2)
  discountAmount     Decimal @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal @db.Decimal(12, 2)

  date              DimDate          @relation(fields: [dateId], references: [dateId])
  startTime         DimTime          @relation("factStartTime", fields: [timeIdStart], references: [timeId])
  endTime           DimTime          @relation("factEndTime", fields: [timeIdEnd], references: [timeId])
  driver            DimDriver        @relation(fields: [driverId], references: [driverId])
  car               DimCar           @relation(fields: [carId], references: [carId])
  customer          DimCustomer      @relation(fields: [customerId], references: [customerId])
  pickupLocation    DimLocation      @relation("factPickup", fields: [pickupLocationId], references: [locationId])
  dropoffLocation   DimLocation      @relation("factDropoff", fields: [dropoffLocationId], references: [locationId])
  status            DimBookingStatus @relation(fields: [statusId], references: [statusId])

  @@index([dateId])
  @@index([driverId])
  @@index([carId])
}
